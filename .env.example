# Konekcija ka Postgres bazi (Neon / Vercel Postgres / Supabase / lokalni Postgres).
# Primer Neon: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# Tajni ključ za potpisivanje login cookie-ja (bilo koji dug nasumičan string).
# Generiši npr.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="promeni-ovo-u-dug-nasumican-string"

# (Opciono) Email obaveštenja preko Resend-a. Ako nije postavljeno, mejlovi su
# isključeni a aplikacija radi normalno. Ključ: https://resend.com → API Keys
RESEND_API_KEY=""
# Pošiljalac. Za test radi onboarding@resend.dev (šalje samo na tvoj Resend nalog).
# Za pravo slanje verifikuj domen u Resend-u i stavi npr. "Odmori <odmori@tvojdomen.rs>"
EMAIL_FROM="Godišnji odmori <onboarding@resend.dev>"
